NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# local keeps using .spectro-data/palettes.json.
# supabase uses the server-side Supabase REST API.
PALETTE_STORAGE_DRIVER=local

# Comma-separated browser origins allowed to call API routes.
# Defaults include hispectro.com, Figma, and localhost development.
SPECTRO_ALLOWED_ORIGINS=
